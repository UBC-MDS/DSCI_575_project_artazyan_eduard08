   "source": [
    "\n",
    "import requests\n",
    "import os\n",
    "\n",
    "url = \"YOUR_DATA_URL\"\n",
    "os.makedirs(\"data/raw\", exist_ok=True)\n",
    "\n",
    "response = requests.get(url)\n",
    "\n",
    "with open(\"data/raw/data.jsonl.gz\", \"wb\") as f:\n",
    "    f.write(response.content)\n",
    "\n",
    "print(\"Download successfull\")"
   ]
  }
